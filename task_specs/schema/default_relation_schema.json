  "social_relations": [
    {
      "type": "kinship_with",
      "description": "两个角色之间法律上、血缘上或文化上认可的家庭或婚姻关系，如亲子、兄弟姐妹、配偶或其他正式家庭纽带。此关系仅适用于叙事明确建立实际家庭或婚姻纽带的情况。不得从比喻性语言、情感亲密、照顾行为、角色相似性(如'像母亲一样')、临时监护或互动层面的动态中推断。",
      "from": [
        "Character"
      ],
      "to": [
        "Character"
      ],
      "persistence": "stable",
      "direction": "symmetric",
      "samples": [
        {
          "subject": "安娜",
          "object": "马克",
          "relation_type": "kinship_with",
          "relation_name": "是...的姐妹",
          "description": "文本确立了安娜和马克是兄妹关系，安娜扮演姐妹角色。"
        }
      ],
      "allow_self_loop": false
    },
    {
      "type": "affinity_with",
      "description": "两方之间以信任、忠诚、合作或一致为特征的正向社会关系状态，在叙事中呈现为当前已建立的状态。此关系反映故事当前阶段的持续纽带，但可能随着事件展开而改变。仅在场景提供强有力、明确的现有正向关系证据时使用(如宣告信任、既定伙伴关系、场景内重复的相互依赖)。不得从礼貌、短暂合作、调情或单次正面互动中推断，以免误将瞬时互动当作稳定关系。",
      "from": [
        "Character",
        "Concept"
      ],
      "to": [
        "Character",
        "Concept"
      ],
      "persistence": "phase",
      "direction": "symmetric",
      "opposite": "hostility_with",
      "samples": [
        {
          "subject": "赵队长",
          "object": "林工程师",
          "relation_type": "affinity_with",
          "relation_name": "信任的伙伴",
          "description": "赵明确称林为信任的伙伴，并以表明故事当前阶段已建立合作关系的方式与林协调行动。"
        }
      ],
      "allow_self_loop": false
    },
    {
      "type": "hostility_with",
      "description": "两方之间以对抗、对立或意图损害对方为特征的负面或敌对关系状态，呈现于叙事当前阶段。此关系代表故事此时的持续敌对立场，但可能随情况变化而转变或化解。仅在场景提供强有力、明确的既定敌对关系证据时使用(如宣告敌意、持续威胁、提及先前冲突)。不得从单次争论、孤立威胁或瞬间对抗中推断，以免误将瞬时互动当作稳定关系。",
      "from": [
        "Character",
        "Concept"
      ],
      "to": [
        "Character",
        "Concept"
      ],
      "persistence": "phase",
      "direction": "symmetric",
      "opposite": "affinity_with",
      "samples": [
        {
          "subject": "叛军领袖",
          "object": "地球联合舰队",
          "relation_type": "hostility_with",
          "relation_name": "持续敌对",
          "description": "叛军领袖将舰队定性为持续对立的敌人，表明叙事当前阶段的既定敌对关系。"
        }
      ],
      "allow_self_loop": false
    },
    {
      "type": "allied_with",
      "description": "组织、机构或派系之间在目的、策略或行动上保持一致的合作或联盟关系。此关系仅适用于Concept实体代表集体社会实体(如组织、机构、派系或社会团体)的情况。不得用于单次互动中的临时合作、个人友谊或与意识形态/技术的抽象认同。",
      "from": [
        "Concept"
      ],
      "to": [
        "Concept"
      ],
      "persistence": "stable",
      "direction": "symmetric",
      "samples": [
        {
          "subject": "叛军派系",
          "object": "外殖民地联盟",
          "relation_type": "allied_with",
          "relation_name": "结盟",
          "description": "文本明确描述这两个团体是为共同目标协调努力的盟友。"
        }
      ],
      "allow_self_loop": false
    },
    {
      "type": "member_of",
